# ============================================================================
# Environment Variables — Example
# ============================================================================
# Copy to .env and replace all CHANGE_ME values.
# Or better: run `make bootstrap` to generate .env from project.yaml.
# ============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=3080
APP_TITLE=My AI Assistant

# --- Database ---
MONGO_URI=mongodb://mongodb:27017/my-ai-assistant

# --- Search ---
SEARCH=true
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_meili_master_key

# --- LLM Provider (choose one) ---
ANTHROPIC_API_KEY=CHANGE_ME_your_anthropic_key
# OPENAI_API_KEY=CHANGE_ME_your_openai_key
# GOOGLE_API_KEY=CHANGE_ME_your_google_key

# --- Security (generate unique values) ---
CREDS_KEY=CHANGE_ME_32_char_credentials_key
CREDS_IV=CHANGE_ME_16_char_creds_iv
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret
