# ============================================================================
# Team-Shared Credentials
# ============================================================================
# These are shared across all PoC deployments by the D&AI Advisory team.
# Store the real version of this file somewhere your team can access:
#   - Your machine: ~/.config/dai-advisory/.env.team
#   - Or: a private Google Drive folder restricted to the team
#
# The deploy script reads from TEAM_ENV_FILE (default: ~/.config/dai-advisory/.env.team)
# ============================================================================

# LLM Gateway (Fuel iX — all PoCs route through this)
FUELIX_API_KEY=your_fuelix_api_key_here

# Railway (account-scoped token for project creation + deployment)
RAILWAY_API_TOKEN=your_railway_api_token_here

# Railway workspace name (your team's Railway workspace)
RAILWAY_WORKSPACE=your_workspace_name

# GitHub org for PoC repos (repos created here by the deploy script)
GITHUB_ORG=your_github_org
